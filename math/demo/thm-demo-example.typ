#statement[
    For any two real numbers $a$ and $b$, $(a + b)^2 = a^2 + 2a b + b^2$.
]

#intuition[
    This is the basic geometric expansion of a square with sides $a+b$.
]

#proof[
    Expand the left side directly by multiplication.
]
]
